{
    "name": "elemix-template",
    "private": true,
    "version": "0.0.0",
    "license": "MIT",
    "type": "module",
    "imports": {
        "#src/*": "./src/*",
        "#stories/*": "./stories/*",
        "#storybook/*": "./.storybook/*"
    },
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "typecheck": "tsc --noEmit",
        "analyze": "ea --dirs src --root .",
        "lint": "biome check . && pnpm lint:tpl",
        "lint:tpl": "etf --dirs src",
        "lint:fix": "biome check --write . && etf --dirs src --write",
        "test": "vitest run",
        "check": "pnpm typecheck && pnpm lint && pnpm analyze"
    },
    "dependencies": {
        "@neuralfog/elemix": "0.9.0-dev.17"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.3",
        "@neuralfog/elemix-analyzer": "0.9.0-dev.17",
        "@neuralfog/elemix-storybook": "0.9.0-dev.17",
        "@neuralfog/elemix-template-formatter": "0.9.0-dev.17",
        "@neuralfog/elemix-vite": "0.9.0-dev.17",
        "@storybook/addon-vitest": "10.4.6",
        "@storybook/html-vite": "10.4.6",
        "@types/node": "26.1.1",
        "@vitest/browser-playwright": "4.1.10",
        "playwright": "1.61.1",
        "sass": "1.101.0",
        "storybook": "10.4.6",
        "typescript": "7.0.2",
        "vite": "8.1.4",
        "vitest": "4.1.10"
    }
}
