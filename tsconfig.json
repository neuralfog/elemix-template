{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "strict": true,
        "skipLibCheck": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "isolatedModules": true,
        "resolveJsonModule": true,
        "useDefineForClassFields": true,
        "noEmit": true,
        "types": ["vite/client"],
        "paths": {
            "#src/*": ["./src/*"]
        }
    },
    "include": ["src"]
}
